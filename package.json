{
  "name": "mcp-interactive-brokers",
  "version": "1.0.0",
  "description": "MCP server for Interactive Brokers API integration - secure API access from sandboxed agents",
  "main": "dist/index.js",
  "bin": {
    "mcp-interactive-brokers": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "interactive-brokers",
    "ibkr",
    "trading",
    "finance",
    "model-context-protocol"
  ],
  "author": "mwaeckerlin",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "node-fetch": "^3.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "diagnostics": {
          "ignoreCodes": [151002]
        }
      }]
    }
  }
}
