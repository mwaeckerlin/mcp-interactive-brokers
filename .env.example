# IB Client Portal Gateway settings
IB_GATEWAY_URL=https://localhost:5000
IB_USERNAME=your_ib_username
IB_PASSWORD=your_ib_password

# Optional: disable TLS verification for local gateway (not recommended for production)
IB_GATEWAY_TLS_REJECT_UNAUTHORIZED=false

# MCP server settings (for SSE transport)
MCP_PORT=3000
